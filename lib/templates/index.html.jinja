<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <style>
    body {
      max-width: 720px;
      margin: 4rem auto;
      padding: 0 1.5rem;
      color: #111827;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    h1 {
      margin-bottom: 0.5rem;
    }

    p {
      color: #4b5563;
      line-height: 1.5;
    }

    .status {
      border-radius: 0.75rem;
      margin-top: 1.5rem;
      padding: 1rem;
    }

    .status.success {
      background: #ecfdf5;
      color: #065f46;
    }

    .status.error {
      background: #fef2f2;
      color: #991b1b;
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-top: 2rem;
    }

    a,
    button {
      appearance: none;
      border: 0;
      border-radius: 0.75rem;
      background: #2563eb;
      color: #ffffff;
      cursor: pointer;
      display: inline-block;
      font: inherit;
      font-weight: 600;
      padding: 0.85rem 1.1rem;
      text-decoration: none;
    }

    button {
      background: #111827;
    }
  </style>
</head>
<body>
  <main>
    <h1>{{ title }}</h1>
    <p>Start the Meet call first, then add the bot when you're ready.</p>

    {% if status_message %}
      <p class="status {{ status_kind }}">{{ status_message }}</p>
    {% endif %}

    <div class="actions">
      <a href="{{ meeting_url }}" target="_blank" rel="noreferrer">Start call</a>
      <form method="post" action="/add-bot">
        <button type="submit">Add bot</button>
      </form>

      {% if bot_id %}
        <form method="post" action="/enable-camera">
          <button type="submit">Enable camera</button>
        </form>
      {% endif %}
    </div>
  </main>
</body>
</html>
